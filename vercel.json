{
  "installCommand": "bun install",
  "buildCommand": "bun run build:web",
  "outputDirectory": "packages/web/dist",
  "headers": [
    {
      "source": "/bk-ai-systems-whatsapp-preview.jpg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
